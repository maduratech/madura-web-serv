{
  "name": "madura-web-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "reload:pm2": "pm2 reload ecosystem.config.cjs --update-env",
    "deploy": "bash scripts/deploy-pm2.sh",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2.17.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/sanitize-html": "^2.16.1",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  }
}
